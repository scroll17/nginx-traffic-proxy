# Copy to .env and adjust. Consumed by gen-certs.sh.
# .env is gitignored — keep real values out of git.

# Comma-separated DB subdomains the SERVER cert must cover (TLS SAN).
# Must match the subdomains routed in nginx.conf's $db_backend map.
DB_GATEWAY_SANS=pg.synergate.space,mongo.synergate.space

# CN the CLIENT cert presents. Must equal --allow-cn in docker-compose.prod.yaml.
DB_CLIENT_CN=db-client

# Subject CNs (cosmetic; SAN is what's actually verified for the server).
DB_CA_CN=db-gateway-ca
DB_SERVER_CN=db-gateway

# Certificate validity in days and RSA key size.
DB_CERT_DAYS=3650
DB_KEY_BITS=4096
